rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "levinhdien9bthcschuvanan@gmail.com"
        );
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['student', 'admin'] &&
             data.createdAt is string;
    }
    
    function isValidApplication(data) {
      return data.keys().hasAll(['userId', 'status', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.status in ['draft', 'submitted', 'assigned', 'approved', 'rejected', 'writing_hardcopy', 'verifying_background'] &&
             data.createdAt is string &&
             data.updatedAt is string;
    }
    
    function isValidCategory(data) {
      return data.keys().hasAll(['type', 'name', 'createdAt']) &&
             data.type in ['religion', 'ethnicity', 'faculty'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                    (request.auth.uid == userId) &&
                    isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidApplication(request.resource.data) && 
                    (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAuthenticated() && isValidApplication(request.resource.data) && 
                    ((request.auth.uid == resource.data.userId && request.resource.data.userId == resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true; // Allow public read for UI config
      allow write: if isAdmin();
    }
    
    match /admin_emails/{emailId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
